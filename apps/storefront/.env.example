# Public catalog API (CARD-38) + OAuth portal (CARD-39)
# Local dev (API on host):
PUBLIC_API_BASE=http://127.0.0.1:9090
PUBLIC_SITE_URL=http://127.0.0.1:4321
# Docker + Funnel (same-origin via Caddy edge) — preferred for Google OAuth cookies:
# PUBLIC_API_BASE=
# PUBLIC_SITE_URL=https://telegram-shop-1.tailXXXX.ts.net
# SSR inside compose uses API_INTERNAL_BASE=http://bot:9090
# API_INTERNAL_BASE=http://bot:9090
#
# Google OAuth is configured on the **API/bot** process (.env), not here.
# Login page reads GET /api/public/auth/config for google_enabled / dev_login_enabled.
