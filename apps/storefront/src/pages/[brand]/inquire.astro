---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { fetchBrand } from "../../lib/api";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");
const brand = await fetchBrand(brandSlug);
if (!brand) return new Response(null, { status: 404 });

const item = Astro.url.searchParams.get("item") || "";
const web = brand.web || {};
const compliance = (web.compliance as Record<string, unknown>) || {};
const warnings = (compliance.footer_warnings as string[]) || [];
const apiBase = (import.meta.env.PUBLIC_API_BASE || "http://127.0.0.1:9090").replace(/\/$/, "");
---

<BaseLayout title="Inquire" brandName={brand.name}>
  <main class="mx-auto max-w-lg py-8 lg:py-12">
    <a href={`/${brandSlug}`} class="text-xs font-medium uppercase tracking-wider text-accent hover:underline">
      ← {brand.name}
    </a>
    <h1 class="mt-3 text-3xl font-bold">Inquire</h1>
    <p class="mt-2 text-sm text-sand-200">
      Request information{item ? ` about “${item}”` : ""}. We’ll contact you on your preferred channel.
    </p>
    <form id="lead-form" class="mt-8 space-y-4">
      <label class="block text-sm">
        <span class="text-ink-500">Name</span>
        <input required name="name" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Phone</span>
        <input name="phone" type="tel" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Email</span>
        <input name="email" type="email" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Preferred channel</span>
        <select name="channel" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2">
          <option value="line">LINE</option>
          <option value="whatsapp">WhatsApp</option>
          <option value="phone">Phone</option>
          <option value="email">Email</option>
          <option value="telegram">Telegram</option>
        </select>
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Message</span>
        <textarea name="message" rows="4" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2"></textarea>
      </label>
      <input type="hidden" name="item" value={item} />
      <label class="flex items-start gap-2 text-xs text-sand-200">
        <input type="checkbox" name="consent" required class="mt-0.5" />
        <span>I consent to be contacted about this inquiry.</span>
      </label>
      {
        brand.age_gate_enabled && (
          <label class="flex items-start gap-2 text-xs text-sand-200">
            <input type="checkbox" name="age_confirmed" required class="mt-0.5" />
            <span>I confirm I am of legal age{brand.min_age ? ` (${brand.min_age}+)` : ""}.</span>
          </label>
        )
      }
      <button type="submit" class="w-full rounded-xl bg-accent py-3 text-sm font-semibold text-ink-950">
        Submit inquiry
      </button>
      <p id="msg" class="hidden text-sm"></p>
    </form>
  </main>
  <SiteFooter brandSlug={brandSlug} legalName={brand.legal?.legal_name} dbdNumber={brand.legal?.dbd_number} warnings={warnings} />
</BaseLayout>

<script define:vars={{ apiBase, brandSlug }}>
  document.getElementById("lead-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const phone = String(fd.get("phone") || "").trim();
    const email = String(fd.get("email") || "").trim();
    const msg = document.getElementById("msg");
    if (!phone && !email) {
      if (msg) {
        msg.textContent = "Phone or email is required.";
        msg.className = "text-sm text-red-400";
        msg.classList.remove("hidden");
      }
      return;
    }
    const res = await fetch(`${apiBase}/api/public/leads`, {
      method: "POST",
      credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        brand_slug: brandSlug,
        name: fd.get("name"),
        phone: phone || null,
        email: email || null,
        preferred_channel: fd.get("channel"),
        item_slug: fd.get("item") || null,
        message: fd.get("message"),
        consent: true,
        age_confirmed: !!fd.get("age_confirmed"),
      }),
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      if (msg) {
        msg.textContent = data.error || "Submit failed";
        msg.className = "text-sm text-red-400";
        msg.classList.remove("hidden");
      }
      return;
    }
    if (msg) {
      msg.textContent = "Thanks — we received your inquiry (#" + data.id + ").";
      msg.className = "text-sm text-accent";
      msg.classList.remove("hidden");
    }
    e.target.reset();
  });
</script>
