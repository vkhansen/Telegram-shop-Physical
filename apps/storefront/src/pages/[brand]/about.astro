---
import BrandShell from "../../layouts/BrandShell.astro";
import PageHeader from "../../components/PageHeader.astro";
import DisclaimerPanel from "../../components/DisclaimerPanel.astro";
import { buildNavChips, can, loadBrandContext } from "../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "about", true)) return new Response(null, { status: 404 });

const chips = buildNavChips(ctx, { active: "about" });
const pageDisclaimers = ctx.compliance.disclaimerBlocks.filter(
  (b) => !b.placement || b.placement === "page" || b.placement === "footer",
);
---

<BrandShell ctx={ctx} title={ctx.about.title} chips={chips}>
  <PageHeader brandSlug={ctx.slug} brandName={ctx.brand.name} title={ctx.about.title} />
  <div class="t-fg mt-6 max-w-2xl whitespace-pre-wrap text-sm leading-relaxed lg:text-base">
    {ctx.about.body}
  </div>

  {
    can(ctx, "faq") && ctx.faq.length > 0 && (
      <section class="mt-12 max-w-2xl border-t border-brand pt-8">
        <h2 class="label-brand">FAQ</h2>
        <dl class="mt-4 space-y-4">
          {ctx.faq.map((f) => (
            <div>
              <dt class="t-fg font-semibold">{f.q}</dt>
              <dd class="t-muted mt-1 text-sm leading-relaxed whitespace-pre-wrap">{f.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )
  }

  {
    pageDisclaimers.length > 0 && (
      <div class="mt-10 max-w-2xl">
        <DisclaimerPanel blocks={pageDisclaimers} />
      </div>
    )
  }
</BrandShell>
