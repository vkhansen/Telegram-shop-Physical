---
/**
 * C-08 Cart — same service spine as Telegram cart_handler.
 * list → remove → clear → checkout CTA
 */
import BrandShell from "../../layouts/BrandShell.astro";
import PageHeader from "../../components/PageHeader.astro";
import { buildNavChips, can, loadBrandContext } from "../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "cart", true) && !can(ctx, "checkout", true)) {
  return new Response(null, { status: 404 });
}

const apiBase = ctx.apiBase;
const chips = buildNavChips(ctx, { active: "cart" });
const storeSlug = ctx.defaultStore?.slug || "";
const checkoutOn = can(ctx, "checkout", true);
const loginUrl = `/${brandSlug}/login?next=${encodeURIComponent(`/${brandSlug}/cart`)}`;
---

<BrandShell ctx={ctx} title="Cart" chips={chips}>
  <main class="py-2" data-page="cart">
    <PageHeader
      brandSlug={ctx.slug}
      brandName={ctx.brand.name}
      title="Cart"
      lead="Same cart as Telegram — add from the menu, then checkout when ready."
    />

    <div class="mt-2 flex flex-wrap items-center gap-3 text-sm">
      <p id="who" class="text-sand-200">Checking session…</p>
      <a href={`/${brandSlug}`} class="text-xs text-accent hover:underline">← Menu</a>
    </div>

    <div
      id="load-err"
      class="mt-4 hidden rounded-xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200"
      role="alert"
    >
    </div>

    <div id="skeleton" class="mt-6 space-y-3">
      <div class="h-16 animate-pulse rounded-xl bg-ink-900"></div>
      <div class="h-16 animate-pulse rounded-xl bg-ink-900"></div>
    </div>

    <ul id="cart-list" class="mt-6 space-y-3" aria-live="polite" data-testid="cart-list"></ul>

    <div id="empty" class="mt-10 hidden text-center" data-testid="cart-empty">
      <p class="text-ink-500">Your cart is empty.</p>
      <a
        href={storeSlug ? `/${brandSlug}/${storeSlug}` : `/${brandSlug}`}
        class="mt-4 inline-flex rounded-xl bg-accent px-5 py-2.5 text-sm font-semibold text-ink-950"
      >
        Browse menu
      </a>
    </div>

    <div
      id="footer"
      class="mt-8 hidden rounded-2xl border border-ink-700 bg-ink-900/60 p-5"
      data-testid="cart-footer"
    >
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-ink-500">Total</p>
          <p id="cart-total" class="text-2xl font-bold text-accent" data-testid="cart-total">—</p>
          <p id="cart-count" class="mt-1 text-xs text-ink-500"></p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            id="btn-clear"
            class="rounded-xl border border-ink-700 px-4 py-2.5 text-sm hover:border-red-500/50 hover:text-red-300"
            data-testid="cart-clear"
          >
            Clear cart
          </button>
          {
            checkoutOn && (
              <a
                id="btn-checkout"
                href={`/${brandSlug}/checkout`}
                class="rounded-xl bg-accent px-5 py-2.5 text-sm font-semibold text-ink-950"
                data-testid="cart-checkout"
              >
                Checkout →
              </a>
            )
          }
        </div>
      </div>
    </div>
  </main>
</BrandShell>

<script define:vars={{ apiBase, brandSlug, loginUrl }}>
  const who = document.getElementById("who");
  const list = document.getElementById("cart-list");
  const empty = document.getElementById("empty");
  const footer = document.getElementById("footer");
  const skeleton = document.getElementById("skeleton");
  const errEl = document.getElementById("load-err");
  const totalEl = document.getElementById("cart-total");
  const countEl = document.getElementById("cart-count");

  function esc(s) {
    return String(s ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function showErr(msg) {
    if (!errEl) return;
    errEl.textContent = msg;
    errEl.classList.remove("hidden");
  }

  async function api(path, init = {}) {
    const res = await fetch(`${apiBase}${path}`, {
      ...init,
      credentials: "include",
      headers: {
        Accept: "application/json",
        ...(init.body ? { "Content-Type": "application/json" } : {}),
        ...(init.headers || {}),
      },
    });
    const data = await res.json().catch(() => null);
    return { res, data };
  }

  async function ensureAuth() {
    const { res, data } = await api("/api/public/auth/me");
    if (!res.ok || !data?.authenticated) {
      if (who) who.innerHTML = `Not signed in · <a class="text-accent hover:underline" href="${loginUrl}">Log in</a>`;
      skeleton?.classList.add("hidden");
      empty?.classList.remove("hidden");
      if (empty) {
        empty.querySelector("p").textContent = "Sign in to view your cart (same account spine as Telegram).";
      }
      return false;
    }
    const name = data.session?.name || data.session?.email || "You";
    if (who) who.textContent = `Signed in as ${name}`;
    return true;
  }

  function renderCart(cart) {
    skeleton?.classList.add("hidden");
    errEl?.classList.add("hidden");
    if (!cart || cart.empty || !cart.items?.length) {
      list.innerHTML = "";
      empty?.classList.remove("hidden");
      footer?.classList.add("hidden");
      return;
    }
    empty?.classList.add("hidden");
    footer?.classList.remove("hidden");
    if (totalEl) totalEl.textContent = cart.total ?? "—";
    if (countEl) countEl.textContent = `${cart.item_count} item(s)`;

    list.innerHTML = cart.items
      .map((it) => {
        const mods = it.selected_modifiers
          ? Object.entries(it.selected_modifiers)
              .map(([k, v]) => `${esc(k)}: ${esc(v)}`)
              .join(" · ")
          : "";
        return `<li class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-ink-700 bg-ink-900 p-4" data-cart-id="${it.cart_id}">
          <div>
            <p class="font-semibold text-sand-50">${esc(it.item_name)}</p>
            <p class="mt-0.5 text-xs text-ink-500">Qty ${esc(it.quantity)} · ${esc(it.price)} each</p>
            ${mods ? `<p class="mt-1 text-xs text-sand-200">${mods}</p>` : ""}
          </div>
          <div class="flex items-center gap-3">
            <span class="font-semibold text-accent">${esc(it.total)}</span>
            <button type="button" class="remove-btn rounded-lg border border-ink-700 px-2.5 py-1 text-xs hover:border-red-500/50 hover:text-red-300" data-id="${it.cart_id}" data-testid="cart-remove">Remove</button>
          </div>
        </li>`;
      })
      .join("");

    list.querySelectorAll(".remove-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id");
        const { res, data } = await api(`/api/public/cart/items/${id}`, { method: "DELETE" });
        if (!res.ok) {
          showErr(data?.error_key || data?.error || "Could not remove item");
          return;
        }
        await loadCart();
      });
    });
  }

  async function loadCart() {
    const { res, data } = await api("/api/public/cart");
    if (res.status === 401) {
      window.location.href = loginUrl;
      return;
    }
    if (!res.ok) {
      skeleton?.classList.add("hidden");
      showErr(data?.error_key || data?.error || "Failed to load cart");
      return;
    }
    renderCart(data);
  }

  document.getElementById("btn-clear")?.addEventListener("click", async () => {
    if (!confirm("Clear entire cart?")) return;
    const { res, data } = await api("/api/public/cart/clear", { method: "POST" });
    if (!res.ok) {
      showErr(data?.error_key || data?.error || "Could not clear cart");
      return;
    }
    await loadCart();
  });

  (async () => {
    if (!(await ensureAuth())) return;
    await loadCart();
  })();
</script>
