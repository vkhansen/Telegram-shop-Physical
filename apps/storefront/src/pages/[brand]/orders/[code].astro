---
/**
 * C-17 order detail + C-14 PromptPay QR re-fetch.
 */
import BrandShell from "../../../layouts/BrandShell.astro";
import PageHeader from "../../../components/PageHeader.astro";
import { buildNavChips, can, loadBrandContext } from "../../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug, code } = Astro.params;
if (!brandSlug || !code) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "order_status", true)) return new Response(null, { status: 404 });

const apiBase = ctx.apiBase;
const chips = buildNavChips(ctx, { active: "orders" });
const orderCode = decodeURIComponent(code);
const loginUrl = `/${brandSlug}/login?next=${encodeURIComponent(`/${brandSlug}/orders/${orderCode}`)}`;
---

<BrandShell ctx={ctx} title={`Order ${orderCode}`} chips={chips}>
  <main class="mx-auto max-w-lg py-2" data-page="order-detail">
    <PageHeader
      brandSlug={ctx.slug}
      brandName={ctx.brand.name}
      title="Order detail"
      lead={orderCode}
    />
    <p class="mt-2 text-sm">
      <a href={`/${brandSlug}/orders`} class="text-accent hover:underline">← All orders</a>
    </p>

    <div
      id="load-err"
      class="mt-4 hidden rounded-xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200"
      role="alert"
    >
    </div>
    <div id="skeleton" class="mt-6 h-40 animate-pulse rounded-2xl bg-ink-900"></div>

    <article id="detail" class="mt-6 hidden space-y-4" data-testid="order-detail">
      <div class="rounded-2xl border border-ink-700 bg-ink-900 p-5">
        <p class="font-mono text-xl font-bold tracking-wide" id="d-code" data-testid="detail-code"></p>
        <p class="mt-2">
          <span id="d-status" class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold uppercase ring-1 ring-inset"></span>
        </p>
        <p class="mt-3 text-sm text-sand-200" id="d-pay"></p>
        <p class="mt-1 text-sm text-ink-500" id="d-addr"></p>
        <p class="mt-1 text-sm text-ink-500" id="d-when"></p>
      </div>
      <ul id="d-items" class="space-y-2"></ul>
      <div id="d-qr" class="hidden rounded-2xl border border-ink-700 bg-ink-900 p-5">
        <p class="text-sm font-semibold">PromptPay QR</p>
        <img id="d-qr-img" alt="PromptPay QR" class="mt-3 max-w-[220px] rounded-xl bg-white p-2" />
        <p id="d-qr-meta" class="mt-2 text-xs text-ink-500"></p>
      </div>
    </article>
  </main>
</BrandShell>

<script define:vars={{ apiBase, brandSlug, orderCode, loginUrl }}>
  function esc(s) {
    return String(s ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function label(st) {
    const m = {
      pending: "Pending",
      reserved: "Reserved",
      confirmed: "Confirmed",
      preparing: "Preparing",
      ready: "Ready",
      out_for_delivery: "Out for delivery",
      delivered: "Delivered",
      cancelled: "Cancelled",
      expired: "Expired",
    };
    return m[(st || "").toLowerCase()] || st;
  }

  function statusCls(st) {
    const s = (st || "").toLowerCase();
    if (s === "delivered") return "bg-emerald-500/15 text-emerald-300 ring-emerald-500/30";
    if (s === "cancelled" || s === "expired") return "bg-ink-700 text-ink-400 ring-ink-600";
    if (s === "out_for_delivery" || s === "ready") return "bg-sky-500/15 text-sky-300 ring-sky-500/30";
    return "bg-ink-800 text-sand-200 ring-ink-600";
  }

  async function api(path) {
    const res = await fetch(`${apiBase}${path}`, { credentials: "include", headers: { Accept: "application/json" } });
    const data = await res.json().catch(() => null);
    return { res, data };
  }

  (async () => {
    const me = await api("/api/public/auth/me");
    if (!me.res.ok || !me.data?.authenticated) {
      window.location.href = loginUrl;
      return;
    }

    const { res, data } = await api(`/api/public/orders/${encodeURIComponent(orderCode)}`);
    document.getElementById("skeleton")?.classList.add("hidden");
    if (res.status === 401) {
      window.location.href = loginUrl;
      return;
    }
    if (!res.ok) {
      const err = document.getElementById("load-err");
      if (err) {
        err.textContent = data?.error_key || data?.error || "Order not found";
        err.classList.remove("hidden");
      }
      return;
    }

    const d = data;
    document.getElementById("detail")?.classList.remove("hidden");
    const codeEl = document.getElementById("d-code");
    if (codeEl) codeEl.textContent = d.order_code;
    const st = document.getElementById("d-status");
    if (st) {
      st.textContent = label(d.order_status);
      st.className =
        "inline-flex rounded-full px-2 py-0.5 text-xs font-semibold uppercase ring-1 ring-inset " +
        statusCls(d.order_status);
    }
    const pay = document.getElementById("d-pay");
    if (pay) pay.textContent = `${d.payment_method} · ${d.total_price}`;
    const addr = document.getElementById("d-addr");
    if (addr) addr.textContent = [d.phone_number, d.delivery_address].filter(Boolean).join(" · ");
    const when = document.getElementById("d-when");
    if (when && d.created_at) {
      try {
        when.textContent = new Date(d.created_at).toLocaleString();
      } catch {
        when.textContent = d.created_at;
      }
    }
    const items = document.getElementById("d-items");
    if (items) {
      items.innerHTML = (d.items || [])
        .map(
          (i) =>
            `<li class="flex justify-between rounded-xl border border-ink-700 bg-ink-900/50 px-4 py-3 text-sm">
              <span>${esc(i.quantity)}× ${esc(i.item_name)}</span>
              <span class="text-accent">${esc(i.price)}</span>
            </li>`,
        )
        .join("");
    }

    const pm = (d.payment_method || "").toLowerCase();
    if (pm === "promptpay" || pm === "qr") {
      const qr = await api(`/api/public/orders/${encodeURIComponent(orderCode)}/promptpay-qr`);
      if (qr.res.ok && qr.data) {
        const box = document.getElementById("d-qr");
        box?.classList.remove("hidden");
        if (qr.data.qr_png_base64) {
          const img = document.getElementById("d-qr-img");
          if (img) img.src = `data:image/png;base64,${qr.data.qr_png_base64}`;
        }
        const meta = document.getElementById("d-qr-meta");
        if (meta) {
          meta.textContent = [qr.data.promptpay_id && `ID ${qr.data.promptpay_id}`, qr.data.amount && `฿${qr.data.amount}`]
            .filter(Boolean)
            .join(" · ");
        }
      }
    }
  })();
</script>
