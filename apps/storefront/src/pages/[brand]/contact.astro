---
import BrandShell from "../../layouts/BrandShell.astro";
import PageHeader from "../../components/PageHeader.astro";
import { buildNavChips, can, loadBrandContext } from "../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "contact", true)) return new Response(null, { status: 404 });

const chips = buildNavChips(ctx, { active: "contact" });
const b = ctx.brand;
const L = ctx.labels;
---

<BrandShell ctx={ctx} title={L.contact} chips={chips}>
  <main class="lg:grid lg:grid-cols-2 lg:gap-12">
    <div>
      <PageHeader brandSlug={ctx.slug} brandName={b.name} title={L.contact} />
      <dl class="mt-6 space-y-4 text-sm">
        {
          b.contact?.support_phone && (
            <div>
              <dt class="text-ink-500">Phone</dt>
              <dd>
                <a class="text-sand-50 hover:text-accent" href={`tel:${b.contact.support_phone}`}>
                  {b.contact.support_phone}
                </a>
              </dd>
            </div>
          )
        }
        {
          b.contact?.support_email && (
            <div>
              <dt class="text-ink-500">Email</dt>
              <dd>
                <a class="text-sand-50 hover:text-accent" href={`mailto:${b.contact.support_email}`}>
                  {b.contact.support_email}
                </a>
              </dd>
            </div>
          )
        }
        {
          b.legal?.legal_name && (
            <div>
              <dt class="text-ink-500">Legal name</dt>
              <dd class="text-sand-50">{b.legal.legal_name}</dd>
            </div>
          )
        }
        {
          b.legal?.dbd_number && ctx.compliance.showDbd && (
            <div>
              <dt class="text-ink-500">DBD / Reg.</dt>
              <dd class="text-sand-50">{b.legal.dbd_number}</dd>
            </div>
          )
        }
      </dl>

      <h2 class="mt-8 text-sm font-semibold uppercase tracking-wider text-ink-500">Branches</h2>
      <ul class="mt-3 space-y-3">
        {
          ctx.stores.map((st) => (
            <li class="rounded-xl border border-ink-700 bg-ink-900 p-4">
              <a href={`/${ctx.slug}/${st.slug}`} class="font-semibold text-sand-50 hover:text-accent">
                {st.name}
              </a>
              {st.address && <p class="mt-1 text-sm text-sand-200">{st.address}</p>}
              {st.phone && (
                <a class="mt-1 block text-sm text-accent" href={`tel:${st.phone}`}>
                  {st.phone}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      {
        Object.keys(ctx.social).length > 0 && (
          <>
            <h2 class="mt-8 text-sm font-semibold uppercase tracking-wider text-ink-500">Social</h2>
            <ul class="mt-2 flex flex-wrap gap-3 text-sm">
              {Object.entries(ctx.social).map(([k, v]) => (
                <li>
                  <a class="text-accent hover:underline" href={v} target="_blank" rel="noopener">
                    {k}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }
    </div>
    <div class="mt-10 lg:mt-0">
      <div class="rounded-2xl border border-ink-700 bg-ink-900 p-6">
        <h2 class="text-lg font-semibold">Get in touch</h2>
        <p class="mt-2 text-sm text-sand-200">Use inquire or book a meeting — content from this brand’s catalog profile.</p>
        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
          {
            can(ctx, "leads") && (
              <a
                href={`/${ctx.slug}/inquire`}
                class="rounded-xl bg-accent px-4 py-3 text-center text-sm font-semibold text-ink-950"
              >
                {L.inquire}
              </a>
            )
          }
          {
            can(ctx, "booking") && (
              <a
                href={`/${ctx.slug}/book`}
                class="rounded-xl border border-ink-700 px-4 py-3 text-center text-sm font-medium"
              >
                {L.book}
              </a>
            )
          }
        </div>
      </div>
    </div>
  </main>
</BrandShell>
