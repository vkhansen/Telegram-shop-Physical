---
import BrandShell from "../../layouts/BrandShell.astro";
import ProfileHeader from "../../components/ProfileHeader.astro";
import HeroEditorial from "../../components/HeroEditorial.astro";
import BenefitsStrip from "../../components/BenefitsStrip.astro";
import FeaturedItem from "../../components/FeaturedItem.astro";
import CatalogSection from "../../components/CatalogSection.astro";
import {
  buildHeaderActions,
  buildNavChips,
  can,
  catalogSubline,
  loadBrandContext,
  loadHomeCatalog,
} from "../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404, statusText: "Not Found" });

const home = await loadHomeCatalog(ctx);
const chips = buildNavChips(ctx, { active: "home", includeCatalogAnchor: true });
const actions = buildHeaderActions(ctx);
const L = ctx.labels;
const b = ctx.brand;
const t = ctx.theme;
const editorial = t.isEditorial;
---

<BrandShell ctx={ctx} title={b.name}>
  {
    editorial && t.chrome.hero === "editorial_display" ? (
      <HeroEditorial
        brandName={b.name}
        tagline={ctx.tagline}
        headline={ctx.hero.headline || ctx.tagline}
        subhead={ctx.hero.subhead || b.description}
        eyebrow={ctx.hero.eyebrow || null}
        actions={actions}
      />
    ) : (
      <ProfileHeader
        name={b.name}
        description={b.description}
        logoUrl={b.logo_url}
        tagline={ctx.tagline}
        actions={actions}
      />
    )
  }

  {
    can(ctx, "benefits") && ctx.benefits.length > 0 && (
      <BenefitsStrip
        benefits={ctx.benefits}
        eyebrow={L.benefitsEyebrow}
        headline={L.benefitsHeadline}
        variant={t.chrome.benefits}
      />
    )
  }

  {
    can(ctx, "featured") && home.featured && home.storeSlug && (
      <FeaturedItem
        item={home.featured}
        brandSlug={b.slug}
        storeSlug={home.storeSlug}
        eyebrow={L.featuredEyebrow}
        badge={L.featuredBadge}
        ctaLabel={L.featuredCta}
        ctaHref="#catalog"
        fallbackBody={ctx.hero.subhead || null}
        variant={t.chrome.featured}
        productMedia={t.chrome.product_media}
      />
    )
  }

  {
    can(ctx, "catalog") && home.storeSlug ? (
      <CatalogSection
        eyebrow={L.catalogEyebrow}
        headline={L.catalogHeadline}
        subline={catalogSubline(ctx, home)}
        items={home.items}
        brandSlug={b.slug}
        storeSlug={home.storeSlug}
        branchHref={`/${b.slug}/${home.storeSlug}`}
        branchLabel={L.openBranch}
        catalogVariant={t.chrome.catalog}
        productMedia={t.chrome.product_media}
        editorial={editorial}
      />
    ) : (
      !can(ctx, "catalog") ? null : (
        <p class="py-12 text-center text-[color:var(--brand-muted,#6b6b73)]">No active stores for this brand.</p>
      )
    )
  }
</BrandShell>
