---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { fetchBrand } from "../../../lib/api";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");
const brand = await fetchBrand(brandSlug);
if (!brand) return new Response(null, { status: 404 });
const apiBase = (import.meta.env.PUBLIC_API_BASE || "http://127.0.0.1:9090").replace(/\/$/, "");
---

<BaseLayout title="New ticket" brandName={brand.name}>
  <main class="mx-auto max-w-lg py-8">
    <a href={`/${brandSlug}/tickets`} class="text-xs text-accent hover:underline">← Tickets</a>
    <h1 class="mt-3 text-3xl font-bold">New support ticket</h1>
    <form id="new-ticket" class="mt-8 space-y-4">
      <label class="block text-sm">
        <span class="text-ink-500">Subject</span>
        <input name="subject" required class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Message</span>
        <textarea name="message" required rows="5" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2"></textarea>
      </label>
      <button type="submit" class="w-full rounded-xl bg-accent py-3 text-sm font-semibold text-ink-950">Create ticket</button>
      <p id="err" class="hidden text-xs text-red-400"></p>
    </form>
  </main>
</BaseLayout>

<script define:vars={{ apiBase, brandSlug }}>
  // require auth
  fetch(`${apiBase}/api/public/auth/me`, { credentials: "include" }).then((r) => {
    if (!r.ok) window.location.href = `/${brandSlug}/login?next=/${brandSlug}/tickets/new`;
  });
  document.getElementById("new-ticket")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const res = await fetch(`${apiBase}/api/public/tickets`, {
      method: "POST",
      credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        subject: fd.get("subject"),
        message: fd.get("message"),
        brand_slug: brandSlug,
      }),
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      const err = document.getElementById("err");
      if (err) {
        err.textContent = data.error || "Failed";
        err.classList.remove("hidden");
      }
      return;
    }
    window.location.href = `/${brandSlug}/tickets/${data.ticket_code}`;
  });
</script>
