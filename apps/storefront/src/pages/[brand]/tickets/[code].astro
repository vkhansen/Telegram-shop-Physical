---
import BrandShell from "../../../layouts/BrandShell.astro";
import PageHeader from "../../../components/PageHeader.astro";
import { can, loadBrandContext } from "../../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug, code } = Astro.params;
if (!brandSlug || !code) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "tickets", true)) return new Response(null, { status: 404 });

const apiBase = ctx.apiBase;
---

<BrandShell ctx={ctx} title={`Ticket ${code}`}>
  <main class="mx-auto max-w-2xl py-2">
    <PageHeader
      brandSlug={ctx.slug}
      brandName={ctx.brand.name}
      title="Ticket"
      backHref={`/${brandSlug}/tickets`}
      backLabel="← All tickets"
    />
    <h1 id="subject" class="mt-2 text-2xl font-bold">Loading…</h1>
    <p id="meta" class="mt-1 text-xs text-ink-500"></p>
    <div id="thread" class="mt-6 space-y-3"></div>
    <form id="reply" class="mt-8 space-y-3 border-t border-ink-800 pt-6">
      <textarea name="message" required rows="3" placeholder="Write a reply…" class="w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2 text-sm"></textarea>
      <button type="submit" class="rounded-xl bg-accent px-5 py-2 text-sm font-semibold text-ink-950">Send reply</button>
    </form>
  </main>
</BrandShell>

<script define:vars={{ apiBase, brandSlug, code }}>
  async function load() {
    const me = await fetch(`${apiBase}/api/public/auth/me`, { credentials: "include" });
    if (!me.ok) {
      window.location.href = `/${brandSlug}/login?next=/${brandSlug}/tickets/${code}`;
      return;
    }
    const res = await fetch(`${apiBase}/api/public/tickets/${code}`, { credentials: "include" });
    if (!res.ok) {
      document.getElementById("subject").textContent = "Ticket not found";
      return;
    }
    const t = await res.json();
    document.getElementById("subject").textContent = t.subject;
    document.getElementById("meta").textContent = `${t.ticket_code} · ${t.status}`;
    const thread = document.getElementById("thread");
    thread.innerHTML = "";
    for (const m of t.messages || []) {
      const div = document.createElement("div");
      const mine = m.sender_role === "user";
      div.className = `rounded-xl p-3 text-sm ${mine ? "bg-accent/10 border border-accent/30 ml-4" : "bg-ink-900 border border-ink-700 mr-4"}`;
      div.innerHTML = `<p class="text-[10px] uppercase text-ink-500">${m.sender_role}</p><p class="mt-1 whitespace-pre-wrap text-sand-50">${m.message_text}</p>`;
      thread.appendChild(div);
    }
  }
  load();
  document.getElementById("reply")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const res = await fetch(`${apiBase}/api/public/tickets/${code}/messages`, {
      method: "POST",
      credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ message: fd.get("message") }),
    });
    if (res.ok) {
      e.target.reset();
      load();
    }
  });
</script>
