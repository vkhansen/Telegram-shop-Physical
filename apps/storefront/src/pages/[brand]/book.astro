---
import BrandShell from "../../layouts/BrandShell.astro";
import PageHeader from "../../components/PageHeader.astro";
import { can, loadBrandContext } from "../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "booking", true)) return new Response(null, { status: 404 });

const L = ctx.labels;
const apiBase = ctx.apiBase;
---

<BrandShell ctx={ctx} title={L.book}>
  <main class="mx-auto max-w-lg py-2">
    <PageHeader
      brandSlug={ctx.slug}
      brandName={ctx.brand.name}
      title={L.book}
      lead="Request an in-person visit or Google Meet call. Staff will confirm and send a Meet link if needed."
    />
    <form id="book-form" class="mt-8 space-y-4">
      <label class="block text-sm">
        <span class="text-ink-500">Name</span>
        <input required name="name" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Phone</span>
        <input name="phone" type="tel" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Email</span>
        <input name="email" type="email" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <fieldset class="text-sm">
        <legend class="text-ink-500">Meeting type</legend>
        <div class="mt-2 flex flex-col gap-2 sm:flex-row">
          <label class="flex items-center gap-2 rounded-xl border border-ink-700 px-3 py-2">
            <input type="radio" name="type" value="in_person" checked /> In person
          </label>
          <label class="flex items-center gap-2 rounded-xl border border-ink-700 px-3 py-2">
            <input type="radio" name="type" value="google_meet" /> Google Meet
          </label>
        </div>
      </fieldset>
      {
        ctx.stores.length > 0 && (
          <label class="block text-sm">
            <span class="text-ink-500">Preferred branch (in person)</span>
            <select name="store" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2">
              {ctx.stores.map((st) => (
                <option value={st.slug}>{st.name}</option>
              ))}
            </select>
          </label>
        )
      }
      <label class="block text-sm">
        <span class="text-ink-500">Preferred date & time</span>
        <input required name="when" type="datetime-local" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2" />
      </label>
      <label class="block text-sm">
        <span class="text-ink-500">Notes</span>
        <textarea name="notes" rows="3" class="mt-1 w-full rounded-xl border border-ink-700 bg-ink-900 px-3 py-2"></textarea>
      </label>
      <button type="submit" class="w-full rounded-xl bg-accent py-3 text-sm font-semibold text-ink-950">
        Request meeting
      </button>
      <p id="msg" class="hidden text-sm"></p>
    </form>
  </main>
</BrandShell>

<script define:vars={{ apiBase, brandSlug: ctx.slug }}>
  document.getElementById("book-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const phone = String(fd.get("phone") || "").trim();
    const email = String(fd.get("email") || "").trim();
    const msg = document.getElementById("msg");
    if (!phone && !email) {
      if (msg) {
        msg.textContent = "Phone or email is required.";
        msg.className = "text-sm text-red-400";
        msg.classList.remove("hidden");
      }
      return;
    }
    const res = await fetch(`${apiBase}/api/public/bookings`, {
      method: "POST",
      credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        brand_slug: brandSlug,
        name: fd.get("name"),
        phone: phone || null,
        email: email || null,
        meeting_type: fd.get("type"),
        store_slug: fd.get("store") || null,
        preferred_when: fd.get("when"),
        notes: fd.get("notes"),
      }),
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      if (msg) {
        msg.textContent = data.error || "Request failed";
        msg.className = "text-sm text-red-400";
        msg.classList.remove("hidden");
      }
      return;
    }
    if (msg) {
      msg.textContent = "Request received (#" + data.id + "). We’ll confirm soon.";
      msg.className = "text-sm text-accent";
      msg.classList.remove("hidden");
    }
    e.target.reset();
  });
</script>
