---
import BrandShell from "../../layouts/BrandShell.astro";
import PageHeader from "../../components/PageHeader.astro";
import { can, loadBrandContext } from "../../lib/brandContext";

export const prerender = false;

const { brand: brandSlug } = Astro.params;
if (!brandSlug) return Astro.redirect("/");

const ctx = await loadBrandContext(brandSlug);
if (!ctx) return new Response(null, { status: 404 });
if (!can(ctx, "auth", true)) return new Response(null, { status: 404 });

const apiBase = ctx.apiBase;
const L = ctx.labels;
---

<BrandShell ctx={ctx} title="Account">
  <main class="mx-auto max-w-lg py-2">
    <PageHeader brandSlug={ctx.slug} brandName={ctx.brand.name} title="Account" />
    <div id="card" class="mt-6 rounded-2xl border border-ink-700 bg-ink-900 p-6">
      <p class="text-sm text-ink-500">Loading profile…</p>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        can(ctx, "tickets") && (
          <a href={`/${brandSlug}/tickets`} class="rounded-xl bg-accent px-4 py-2 text-sm font-semibold text-ink-950">
            {L.support}
          </a>
        )
      }
      <button id="logout" type="button" class="rounded-xl border border-ink-700 px-4 py-2 text-sm">Log out</button>
    </div>
  </main>
</BrandShell>

<script define:vars={{ apiBase, brandSlug }}>
  async function load() {
    const res = await fetch(`${apiBase}/api/public/auth/me`, { credentials: "include" });
    if (!res.ok) {
      window.location.href = `/${brandSlug}/login?next=/${brandSlug}/account`;
      return;
    }
    const data = await res.json();
    const p = data.profile || {};
    const card = document.getElementById("card");
    if (!card) return;
    card.innerHTML = `
      <div class="flex items-center gap-4">
        ${p.avatar ? `<img src="${p.avatar}" alt="" class="h-14 w-14 rounded-full object-cover" />` : `<div class="flex h-14 w-14 items-center justify-center rounded-full bg-ink-800 text-accent">${(p.name || p.email || "?")[0]}</div>`}
        <div>
          <p class="font-semibold text-sand-50">${p.name || "—"}</p>
          <p class="text-sm text-sand-200">${p.email || ""}</p>
        </div>
      </div>
    `;
  }
  load();
  document.getElementById("logout")?.addEventListener("click", async () => {
    await fetch(`${apiBase}/api/public/auth/logout`, { method: "POST", credentials: "include" });
    window.location.href = `/${brandSlug}`;
  });
</script>
