---
/**
 * Standard white-label chrome for every brand page.
 * AgeGate + Ticker + chips/nav + body + SiteFooter — all from BrandContext (DB + capabilities).
 */
import BaseLayout from "./BaseLayout.astro";
import AgeGate from "../components/AgeGate.astro";
import TickerStrip from "../components/TickerStrip.astro";
import StoryChips from "../components/StoryChips.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { type BrandContext, type NavChip, buildFooterLinks, buildHeaderActions, can } from "../lib/brandContext";
import { themeCssVars, themeFontHref } from "../lib/theme";

interface Props {
  ctx: BrandContext;
  title: string;
  description?: string;
  chips?: NavChip[];
  showTicker?: boolean;
  ageGate?: boolean;
}

const {
  ctx,
  title,
  description = "",
  chips = [],
  showTicker = true,
  ageGate = true,
} = Astro.props;

const { brand, compliance: cmp, theme } = ctx;
const desc = description || brand.description || "";
const footerLinks = buildFooterLinks(ctx);
const gateOn = ageGate && can(ctx, "age_gate", brand.age_gate_enabled);
const tickerOn = showTicker && can(ctx, "ticker", true);
const cssVars = themeCssVars(theme);
const fontHref = themeFontHref(theme);
const editorial = theme.isEditorial;
const actions = buildHeaderActions(ctx);
const stickyNav = theme.chrome.nav === "sticky_full";
---

<BaseLayout
  title={title}
  description={desc}
  brandName={brand.name}
  cssVars={cssVars}
  fontHref={fontHref}
  themeMode={theme.mode}
  containerClass={[
    "brand-shell",
    theme.mode === "light" ? "theme-light" : "theme-dark",
    editorial ? "theme-editorial" : "",
    "mx-auto min-h-screen w-full px-3 sm:px-4 lg:px-6",
    editorial ? "" : "max-w-site",
  ]
    .filter(Boolean)
    .join(" ")}
>
  {
    gateOn && (
      <AgeGate
        enabled={brand.age_gate_enabled}
        minAge={brand.min_age}
        title={cmp.ageGate.title}
        body={cmp.ageGate.body}
        confirmLabel={cmp.ageGate.confirmLabel}
        denyLabel={cmp.ageGate.denyLabel}
        footerNote={cmp.ageGate.footerNote}
        denyRedirectUrl={cmp.ageGate.denyRedirectUrl}
        disclaimerLines={cmp.ageGate.disclaimerLines}
        brandName={brand.name}
        brandSlug={brand.slug}
        logoUrl={brand.logo_url}
        variant={theme.chrome.age_gate}
      />
    )
  }

  {tickerOn && <TickerStrip text={cmp.ticker} variant={theme.chrome.ticker} />}

  {
    stickyNav && chips.length > 0 ? (
      <SiteNav brandName={brand.name} brandSlug={brand.slug} chips={chips} actions={actions} />
    ) : chips.length > 0 ? (
      <StoryChips chips={chips} />
    ) : null
  }

  <slot />

  <SiteFooter
    brandSlug={brand.slug}
    legalName={brand.legal?.legal_name}
    dbdNumber={brand.legal?.dbd_number}
    warnings={cmp.footerWarnings}
    disclaimers={cmp.disclaimerBlocks}
    legalNote={cmp.legalNote}
    showDbd={cmp.showDbd}
    links={footerLinks}
  />
</BaseLayout>
