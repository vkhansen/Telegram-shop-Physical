---
import ProductGrid from "./ProductGrid.astro";
import type { CatalogItem } from "../lib/api";

interface Props {
  eyebrow: string;
  headline: string;
  subline: string;
  items: CatalogItem[];
  brandSlug: string;
  storeSlug: string;
  branchHref?: string | null;
  branchLabel?: string | null;
  id?: string;
  catalogVariant?: string;
  productMedia?: string;
  editorial?: boolean;
}

const {
  eyebrow,
  headline,
  subline,
  items,
  brandSlug,
  storeSlug,
  branchHref = null,
  branchLabel = null,
  id = "catalog",
  catalogVariant = "ig_grid",
  productMedia = "photo_or_vector",
  editorial = false,
} = Astro.props;
---

<section id={id} class="border-t border-brand pb-10 pt-8">
  <p class:list={[editorial ? "sec-eye t-sea" : "label-brand"]}>{eyebrow}</p>
  <div class="mt-2 mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2
        class:list={[
          editorial
            ? "display t-fg mt-1 text-2xl tracking-tight sm:text-4xl"
            : "t-fg mt-1 text-2xl font-bold tracking-tight sm:text-3xl",
        ]}
      >
        {headline}
      </h2>
      {subline && <p class="t-muted mt-1 text-sm">{subline}</p>}
    </div>
    {
      branchHref && branchLabel && (
        <a class="t-sea text-sm font-semibold hover:underline" href={branchHref}>
          {branchLabel}
        </a>
      )
    }
  </div>
  <ProductGrid
    items={items}
    brandSlug={brandSlug}
    storeSlug={storeSlug}
    variant={catalogVariant}
    productMedia={productMedia}
  />
</section>
