---
/** Numbered benefit cards — always brand-token colors (no sand/ink hardcodes). */
interface Benefit {
  n?: string;
  title: string;
  body: string;
}

interface Props {
  benefits: Benefit[];
  eyebrow: string;
  headline: string;
  /** cards (default) | ink_strip_numbers */
  variant?: string;
}

const { benefits, eyebrow, headline, variant = "cards" } = Astro.props;
const ink = variant === "ink_strip_numbers";
---

{
  benefits.length > 0 &&
    (ink ? (
      <section class="border-t border-brand py-10 lg:py-14">
        <p class="sec-eye t-sea">{eyebrow}</p>
        <h2 class="display t-fg mt-3 max-w-2xl text-2xl tracking-tight sm:text-4xl">{headline}</h2>
        <div class="benefits-ink mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {benefits.map((b, i) => (
            <article>
              <p class="num">{b.n || String(i + 1).padStart(2, "0")}</p>
              <h3 class="t-on-ink mt-3 text-base font-semibold">{b.title}</h3>
              <p class="mt-2 text-sm leading-relaxed opacity-80" style="color:var(--brand-on-ink);">
                {b.body}
              </p>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <section class="border-t border-brand py-10 lg:py-14">
        <p class="label-brand">{eyebrow}</p>
        <h2 class="t-fg mt-2 max-w-xl text-2xl font-bold tracking-tight sm:text-3xl">{headline}</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {benefits.map((b, i) => (
            <article class="panel-brand rounded-2xl p-5">
              <p class="t-accent text-xs font-semibold">{b.n || String(i + 1).padStart(2, "0")}</p>
              <h3 class="t-fg mt-2 text-base font-semibold">{b.title}</h3>
              <p class="t-muted mt-2 text-sm leading-relaxed">{b.body}</p>
            </article>
          ))}
        </div>
      </section>
    ))
}
