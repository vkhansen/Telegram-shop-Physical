---
/** Numbered benefit cards — copy from web_profile.benefits + section labels. */
interface Benefit {
  n?: string;
  title: string;
  body: string;
}

interface Props {
  benefits: Benefit[];
  eyebrow: string;
  headline: string;
  /** cards (default) | ink_strip_numbers */
  variant?: string;
}

const { benefits, eyebrow, headline, variant = "cards" } = Astro.props;
const ink = variant === "ink_strip_numbers";
---

{
  benefits.length > 0 &&
    (ink ? (
      <section class="border-t border-[color:var(--brand-line)] py-10 lg:py-14">
        <p class="sec-eye text-[color:var(--brand-sea)]">{eyebrow}</p>
        <h2 class="display mt-3 max-w-2xl text-2xl tracking-tight text-[color:var(--brand-ink)] sm:text-4xl">
          {headline}
        </h2>
        <div class="benefits-ink mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {benefits.map((b, i) => (
            <article>
              <p class="num">{b.n || String(i + 1).padStart(2, "0")}</p>
              <h3 class="mt-3 text-base font-semibold text-[color:var(--brand-on-ink)]">{b.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{b.body}</p>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <section class="border-t border-ink-800 py-10 lg:py-14">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-accent">{eyebrow}</p>
        <h2 class="mt-2 max-w-xl text-2xl font-bold tracking-tight text-sand-50 sm:text-3xl">{headline}</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {benefits.map((b, i) => (
            <article class="rounded-2xl border border-ink-800 bg-ink-900/60 p-5">
              <p class="text-xs font-semibold text-accent">{b.n || String(i + 1).padStart(2, "0")}</p>
              <h3 class="mt-2 text-base font-semibold text-sand-50">{b.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand-200">{b.body}</p>
            </article>
          ))}
        </div>
      </section>
    ))
}
