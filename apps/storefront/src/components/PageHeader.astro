---
/** Standardized back-link + title + optional lead for inner brand pages. */
interface Props {
  brandSlug: string;
  brandName: string;
  title: string;
  lead?: string | null;
  backHref?: string;
  backLabel?: string;
}

const {
  brandSlug,
  brandName,
  title,
  lead = null,
  backHref,
  backLabel,
} = Astro.props;

const href = backHref || `/${brandSlug}`;
const label = backLabel || `← ${brandName}`;
---

<header class="border-b border-ink-800 py-6 lg:py-8">
  <a href={href} class="text-xs font-medium uppercase tracking-wider text-accent hover:underline">
    {label}
  </a>
  <h1 class="mt-3 text-3xl font-bold tracking-tight text-sand-50 lg:text-4xl">{title}</h1>
  {lead && <p class="mt-2 max-w-2xl text-sm leading-relaxed text-sand-200">{lead}</p>}
  <slot />
</header>
