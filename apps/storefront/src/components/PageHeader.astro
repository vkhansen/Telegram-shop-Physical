---
/** Standardized back-link + title — brand tokens only (light/dark safe). */
interface Props {
  brandSlug: string;
  brandName: string;
  title: string;
  lead?: string | null;
  backHref?: string;
  backLabel?: string;
}

const {
  brandSlug,
  brandName,
  title,
  lead = null,
  backHref,
  backLabel,
} = Astro.props;

const href = backHref || `/${brandSlug}`;
const label = backLabel || `← ${brandName}`;
---

<header class="border-b border-brand py-6 lg:py-8">
  <a href={href} class="t-accent text-xs font-medium uppercase tracking-wider hover:underline">
    {label}
  </a>
  <h1 class="t-fg mt-3 text-3xl font-bold tracking-tight lg:text-4xl">{title}</h1>
  {lead && <p class="t-muted mt-2 max-w-2xl text-sm leading-relaxed">{lead}</p>}
  <slot />
</header>
