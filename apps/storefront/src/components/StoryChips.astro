---
interface Chip {
  href: string;
  label: string;
  active?: boolean;
}

interface Props {
  chips: Chip[];
}

const { chips } = Astro.props;
---

<nav
  class="scrollbar-none -mx-1 flex gap-2 overflow-x-auto py-3"
  aria-label="Locations and sections"
>
  {
    chips.map((c) => (
      <a
        href={c.href}
        class:list={[
          "shrink-0 rounded-full border px-4 py-2 text-sm font-medium transition border-brand",
          c.active ? "bg-accent-solid" : "t-fg bg-paper hover:bg-surface",
        ]}
      >
        {c.label}
      </a>
    ))
  }
</nav>
