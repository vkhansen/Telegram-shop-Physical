---
import type { CatalogItem } from "../lib/api";

interface Props {
  item: CatalogItem;
  brandSlug: string;
  storeSlug: string;
  eyebrow: string;
  badge: string;
  ctaLabel: string;
  ctaHref: string;
  fallbackBody?: string | null;
}

const { item, brandSlug, storeSlug, eyebrow, badge, ctaLabel, ctaHref, fallbackBody = null } =
  Astro.props;
---

<section class="border-t border-ink-800 py-10">
  <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-accent">{eyebrow}</p>
  <div class="mt-4 grid items-center gap-6 md:grid-cols-2">
    <a
      href={`/${brandSlug}/${storeSlug}/i/${item.slug}`}
      class="group relative aspect-square overflow-hidden rounded-2xl bg-ink-900 sm:aspect-[4/3]"
    >
      {
        item.image_url ? (
          <img
            src={item.image_url}
            alt={item.name}
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          />
        ) : (
          <div class="flex h-full items-center justify-center text-sand-200">{item.name}</div>
        )
      }
    </a>
    <div>
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-accent">{badge}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-sand-50 sm:text-4xl">
        {item.name}<span class="text-accent">.</span>
      </h2>
      <p class="mt-3 max-w-md text-sm leading-relaxed text-sand-200">
        {item.description || fallbackBody || ""}
      </p>
      <a
        class="mt-6 inline-flex rounded-full bg-sand-50 px-5 py-2.5 text-sm font-semibold text-ink-950 transition hover:bg-accent"
        href={ctaHref}
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</section>
