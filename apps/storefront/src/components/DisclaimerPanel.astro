---
/**
 * Informational disclaimer panel — brand tokens only.
 */
interface Block {
  id?: string;
  title?: string;
  body: string;
}

interface Props {
  blocks?: Block[];
  body?: string | null;
  title?: string | null;
  compact?: boolean;
}

const { blocks = [], body = null, title = null, compact = false } = Astro.props;

const list: Block[] = [
  ...blocks.filter((b) => b?.body),
  ...(body && !blocks.some((b) => b.body === body)
    ? [{ title: title || undefined, body }]
    : []),
];
---

{
  list.length > 0 && (
    <aside
      class:list={[
        "panel-brand rounded-2xl",
        compact ? "px-3 py-2.5 text-[11px]" : "px-4 py-4 text-xs",
      ]}
      role="note"
      aria-label="Notices"
    >
      <div class="space-y-3">
        {list.map((b) => (
          <div>
            {b.title && <p class="label-brand mb-1">{b.title}</p>}
            <p class="t-muted whitespace-pre-wrap leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </aside>
  )
}
