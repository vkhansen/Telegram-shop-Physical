---
/**
 * White-label footer: legal identity, tenant warnings, structured disclaimers.
 * Nav links come from capability-filtered builder — no hard-coded vertical links.
 */
interface DisclaimerBlock {
  id?: string;
  title?: string;
  body: string;
}

interface FooterLink {
  href: string;
  label: string;
}

interface Props {
  legalName?: string | null;
  dbdNumber?: string | null;
  warnings?: string[];
  disclaimers?: DisclaimerBlock[];
  legalNote?: string | null;
  showDbd?: boolean;
  brandSlug: string;
  links?: FooterLink[];
}

const {
  legalName,
  dbdNumber,
  warnings = [],
  disclaimers = [],
  legalNote = null,
  showDbd = true,
  brandSlug,
  links = [],
} = Astro.props;

const strips = (warnings || []).filter(Boolean);
const blocks = (disclaimers || []).filter((d) => {
  if (!d?.body) return false;
  if (strips.some((w) => w === d.body)) return false;
  return true;
});

const nav =
  links.length > 0
    ? links
    : [
        { href: `/${brandSlug}`, label: "Home" },
        { href: `/${brandSlug}/about`, label: "About" },
        { href: `/${brandSlug}/contact`, label: "Contact" },
      ];
---

<footer
  class="mt-12 border-t border-[color:var(--brand-line)] py-8 text-sm text-[color:var(--brand-muted)]"
  style="background:var(--brand-footer);color:var(--brand-on-footer);"
>
  {
    strips.length > 0 && (
      <div
        class="mb-4 rounded-xl border border-[color:var(--brand-line)] px-4 py-3 text-xs leading-relaxed"
        style="background:color-mix(in srgb, var(--brand-sun) 12%, var(--brand-footer));color:var(--brand-on-footer);"
        role="note"
        aria-label="Legal warnings"
      >
        {strips.map((w) => (
          <p class="font-medium">{w}</p>
        ))}
      </div>
    )
  }

  {
    blocks.length > 0 && (
      <div class="mb-6 space-y-3">
        {blocks.map((d) => (
          <div
            class="rounded-xl border border-[color:var(--brand-line)] px-4 py-3 text-xs leading-relaxed"
            style="background:color-mix(in srgb, var(--brand-on-footer) 6%, var(--brand-footer));color:var(--brand-on-footer);"
          >
            {d.title && (
              <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.18em] opacity-70">{d.title}</p>
            )}
            <p class="whitespace-pre-wrap opacity-90">{d.body}</p>
          </div>
        ))}
      </div>
    )
  }

  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="space-y-1">
      {legalName && <p class="font-medium text-[color:var(--brand-on-footer)]">{legalName}</p>}
      {showDbd && dbdNumber && <p class="opacity-80">DBD / Reg. No. {dbdNumber}</p>}
      <nav class="mt-2 flex flex-wrap gap-3" aria-label="Footer">
        {nav.map((l) => (
          <a class="text-[color:var(--brand-on-footer)] underline-offset-2 opacity-90 hover:opacity-100 hover:underline" href={l.href}>
            {l.label}
          </a>
        ))}
      </nav>
    </div>
    {
      legalNote && (
        <div class="max-w-md space-y-2 text-xs leading-relaxed opacity-75">
          <p>{legalNote}</p>
        </div>
      )
    }
  </div>
</footer>
