# .env.example
# SECURITY WARNING: Never commit real credentials to version control!
# Copy this file to .env and fill with actual values

# === TELEGRAM CONFIGURATION ===
# Get from @BotFather
TOKEN=your_bot_token_here
# Your Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# === PAYMENT CONFIGURATION ===

# Currency for payments (3-letter code: THB, USD, EUR, etc.)
PAY_CURRENCY=THB

# Payment limits (for user management balance)
MIN_AMOUNT=20
MAX_AMOUNT=10000

# === LINKS & UI CONFIGURATION ===
# Telegram channel for notifications (optional)
# Format: @channelname or https://t.me/channelname
CHANNEL_URL=

# Support user ID (optional)
HELPER_ID=

# Bot rules text (optional)
RULES="1. Be respectful\n2. No spam\n3. Follow Telegram ToS"

# === LOCALIZATION & LOGGING ===
# Bot language (th, en, or ru)
BOT_LOCALE=th

# Logging configuration (1 to enable, 0 to disable)
LOG_TO_STDOUT=1
LOG_TO_FILE=1
DEBUG=0

# === REDIS CONFIGURATION ===
# For FSM storage and caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Set password if Redis requires authentication
REDIS_PASSWORD=

# === DATABASE CONFIGURATION ===
# PostgreSQL settings
POSTGRES_DB=telegram_shop
POSTGRES_USER=shop_user
# SECURITY: Use strong password!
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_HOST=localhost
DB_PORT=5432
# Don't change unless you know what you're doing
DB_DRIVER=postgresql+psycopg2

# === MONITORING CONFIGURATION ===
MONITORING_HOST=localhost
MONITORING_PORT=9090

# === PROMPTPAY CONFIGURATION ===
# PromptPay ID for QR payment (phone number or national ID)
PROMPTPAY_ID=0812345678
PROMPTPAY_ACCOUNT_NAME=Restaurant Name

# === SLIP VERIFICATION ===
# Configure one or more providers to auto-verify PromptPay payment slips.
# All providers verify slips from ANY Thai bank with a single API key.
# Tried in order: SlipOK → EasySlip → RDCW. Leave blank for manual-only.

# SlipOK (https://slipok.com) — free tier: 100 slips/month
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=

# EasySlip (https://easyslip.com) — built-in duplicate detection
EASYSLIP_API_KEY=

# RDCW (https://slip.rdcw.co.th) — pay-as-you-go, cheapest at volume
RDCW_CLIENT_ID=
RDCW_CLIENT_SECRET=

# Set to 0 to disable auto-verification (manual admin review only)
SLIP_AUTO_VERIFY=1

# === SUPPORT / MAINTAINERS ===
# Comma-separated Telegram IDs of app maintainers (for live chat + bug reports)
MAINTAINER_IDS=
# Telegram group/channel ID where support staff monitor tickets
SUPPORT_CHAT_ID=

# === KITCHEN & DELIVERY GROUPS (Card 9) ===
# Telegram group IDs for kitchen staff and riders
KITCHEN_GROUP_ID=
RIDER_GROUP_ID=

# === RESTAURANT LOCATION (Card 10) ===
# GPS coordinates for delivery zone calculation
RESTAURANT_LAT=13.7563
RESTAURANT_LNG=100.5018

# === TIMEZONE ===
# Timezone for all timestamps and displays (default: Asia/Bangkok)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Bangkok

# === GROK AI ASSISTANT (Card 17) ===
# xAI API key for Grok-powered admin assistant
# Get from: https://console.x.ai/
GROK_API_KEY=
# Model to use (grok-3-mini for speed, grok-3 for quality)
GROK_MODEL=grok-3-mini
# API timeout in seconds
GROK_TIMEOUT=30

# === PDPA PRIVACY POLICY ===
# URL to your full privacy policy page (required for PDPA compliance)
PRIVACY_POLICY_URL=https://yourbotname.com/privacy
# Contact email for data protection inquiries
PRIVACY_CONTACT_EMAIL=privacy@yourbotname.com
# Company name shown in privacy notice (data controller name)
PRIVACY_COMPANY_NAME=Your Company Name

# === DOCKER SPECIFIC ===
# These are used when running with Docker Compose
# DB_HOST is automatically set to 'db' in Docker environment
DB_HOST=db