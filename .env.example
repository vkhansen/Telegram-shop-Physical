# .env.example
# SECURITY WARNING: Never commit real credentials to version control!
# Copy this file to .env and fill with actual values

# === TELEGRAM CONFIGURATION ===
# Get from @BotFather
TOKEN=your_bot_token_here
# Public bot username without @ (for invite-card deep links / QR)
# BOT_USERNAME=YourBotUsername
# If TOKEN is missing/invalid but you still want Funnel + storefront API:
# WEB_API_ONLY=1
# Your Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# === PAYMENT CONFIGURATION ===

# Currency for payments (3-letter code: THB, USD, EUR, etc.)
PAY_CURRENCY=THB

# Payment limits (for user management balance)
MIN_AMOUNT=20
MAX_AMOUNT=10000

# === LINKS & UI CONFIGURATION ===
# Telegram channel for notifications (optional)
# Format: @channelname or https://t.me/channelname
CHANNEL_URL=

# Support user ID (optional)
HELPER_ID=

# Bot rules text (optional)
RULES="1. Be respectful\n2. No spam\n3. Follow Telegram ToS"

# === LOCALIZATION & LOGGING ===
# Bot language (th, en, or ru)
BOT_LOCALE=th

# Logging configuration (1 to enable, 0 to disable)
LOG_TO_STDOUT=1
LOG_TO_FILE=1
DEBUG=0

# === REDIS CONFIGURATION ===
# For FSM storage and caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Set password if Redis requires authentication
REDIS_PASSWORD=

# === DATABASE CONFIGURATION ===
# PostgreSQL settings
POSTGRES_DB=telegram_shop
POSTGRES_USER=shop_user
# SECURITY: Use strong password!
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_HOST=localhost
DB_PORT=5432
# Don't change unless you know what you're doing
DB_DRIVER=postgresql+psycopg2

# === MONITORING CONFIGURATION ===
MONITORING_HOST=localhost
MONITORING_PORT=9090

# === PROMPTPAY CONFIGURATION ===
# PromptPay ID for QR payment (phone number or national ID)
PROMPTPAY_ID=0812345678
PROMPTPAY_ACCOUNT_NAME=Restaurant Name

# === SLIP VERIFICATION ===
# Configure one or more providers to auto-verify PromptPay payment slips.
# All providers verify slips from ANY Thai bank with a single API key.
# Tried in order: SlipOK → EasySlip → RDCW. Leave blank for manual-only.

# SlipOK (https://slipok.com) — free tier: 100 slips/month
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=

# EasySlip (https://easyslip.com) — built-in duplicate detection
EASYSLIP_API_KEY=

# RDCW (https://slip.rdcw.co.th) — pay-as-you-go, cheapest at volume
RDCW_CLIENT_ID=
RDCW_CLIENT_SECRET=

# Set to 0 to disable auto-verification (manual admin review only)
SLIP_AUTO_VERIFY=1

# === SUPPORT / MAINTAINERS ===
# Comma-separated Telegram IDs of app maintainers (for live chat + bug reports)
MAINTAINER_IDS=
# Telegram group/channel ID where support staff monitor tickets
SUPPORT_CHAT_ID=

# === KITCHEN & DELIVERY GROUPS (Card 9) ===
# Telegram group IDs for kitchen staff and riders
KITCHEN_GROUP_ID=
RIDER_GROUP_ID=

# === RESTAURANT LOCATION (Card 10) ===
# GPS coordinates for delivery zone calculation
RESTAURANT_LAT=13.7563
RESTAURANT_LNG=100.5018

# === TIMEZONE ===
# Timezone for all timestamps and displays (default: Asia/Bangkok)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Bangkok

# === LINE MESSAGING CHANNEL (Card 16) ===
# Flag-off by default (zero Telegram impact). Set true only with real OA tokens.
LINE_CHANNEL_ENABLED=false
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_PATH=/webhooks/line
LINE_DEFAULT_BRAND_ID=
# Multi-OA → brand: UoaBotUserId1:1,UoaBotUserId2:2  (or JSON object)
LINE_OA_BRAND_MAP=
# memory (default) or redis (multi-worker)
LINE_SESSION_BACKEND=memory
LINE_USE_FLEX=true
# Public HTTPS base so LINE can fetch PromptPay QR images (/media/line-qr/...)
# PUBLIC_MEDIA_BASE_URL=https://your.public.host

# === GROK AI ASSISTANT (Card 17) ===
# xAI API key for Grok-powered admin assistant
# Get from: https://console.x.ai/
GROK_API_KEY=
# Model to use (grok-3-mini for speed, grok-3 for quality)
GROK_MODEL=grok-3-mini
# API timeout in seconds
GROK_TIMEOUT=30

# === PDPA PRIVACY POLICY ===
# URL to your full privacy policy page (required for PDPA compliance)
PRIVACY_POLICY_URL=https://yourbotname.com/privacy
# Contact email for data protection inquiries
PRIVACY_CONTACT_EMAIL=privacy@yourbotname.com
# Company name shown in privacy notice (data controller name)
PRIVACY_COMPANY_NAME=Your Company Name

# === PGWEB — DATABASE EXPLORER ===
# Read-only web UI for browsing database schema & data (via Tailscale)
# Access at http://<tailscale-ip>:8081
PGWEB_USER=admin
PGWEB_PASSWORD=change_me_to_strong_password

# === TAILSCALE VPN + FUNNEL ===
# Auth key: https://login.tailscale.com/admin/settings/keys (reusable recommended)
# Prerequisites for Funnel: MagicDNS ON, HTTPS certs ON, ACL nodeAttrs funnel —
# see deploy/tailscale/README.md
TS_AUTHKEY=tskey-auth-xxxx
# Public HTTPS (default) or tailnet-only HTTPS:
#   serve-funnel.json   → https://telegram-shop.<tailnet>.ts.net/ (internet)
#   serve-private.json  → same URL but tailnet members only
TS_SERVE_CONFIG_FILE=serve-funnel.json
# REQUIRED when Funnel is on — protects /dashboard, /metrics, etc.
# MONITORING_API_KEY=change_me_to_long_random_secret
# Funnel public site (Astro + API via Caddy edge)
# PUBLIC_SITE_URL=https://telegram-shop-1.tailXXXX.ts.net
# Leave PUBLIC_MEDIA_BASE_URL empty for same-origin /media via Funnel, or set absolute:
# PUBLIC_MEDIA_BASE_URL=https://telegram-shop-1.tailXXXX.ts.net

# === WEB OAUTH + TICKETS (CARD-39) ===
# Session signing (required for production — do not reuse TOKEN)
# WEB_SESSION_SECRET=openssl_rand_base64_48
# Secure cookies on HTTPS Funnel (recommended true in deploy)
# WEB_COOKIE_SECURE=true
# Local-only passwordless login (NEVER true in production with real traffic)
# OAUTH_DEV_LOGIN=false
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# Authorized redirect URI must match EXACTLY (same-origin Funnel recommended):
#   https://telegram-shop.<tailnet>.ts.net/api/public/auth/google/callback
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# Optional override if API is not same-origin as PUBLIC_SITE_URL:
# OAUTH_GOOGLE_REDIRECT_URI=https://telegram-shop.<tailnet>.ts.net/api/public/auth/google/callback
# Link OAuth user to existing account by verified email (default true)
# OAUTH_LINK_BY_EMAIL=true

# === DOCKER SPECIFIC ===
# These are used when running with Docker Compose
# DB_HOST is automatically set to 'db' in Docker environment
DB_HOST=db